! ------------------------------------------------------------------------------
! SECTION 1: INTERFACES
! ------------------------------------------------------------------------------

!
interface Loopback10
 description BGP_PEER_SOURCE
 ip address 10.10.0.4 255.255.255.255
 ip router isis INFRA-FABRIC
!

! ------------------------------------------------------------------------------
! SECTION 2: BGP
! ------------------------------------------------------------------------------

router bgp 65000
 bgp log-neighbor-changes
 bgp router-id 10.10.0.4
 no bgp default ipv4-unicast

 neighbor 10.10.0.1 remote-as 65000
 neighbor 10.10.0.1 update-source Loopback10
 neighbor 10.10.0.2 remote-as 65000
 neighbor 10.10.0.2 update-source Loopback10
 
 address-family ipv4
  exit-address-family

 address-family l2vpn evpn
  neighbor 10.10.0.1 activate
  neighbor 10.10.0.1 send-community both
  neighbor 10.10.0.2 activate
  neighbor 10.10.0.2 send-community both

! ------------------------------------------------------------------------------
! SECTION 3: Multi-Tenant VRF & VXLAN EVPN Mapping
! ------------------------------------------------------------------------------

!Configure VRF A
vrf definition Tenant_A
 rd 10.10.0.4:10010
 address-family ipv4
 route-target export 65000:10010 stitching
 route-target import 65000:10010 stitching
 exit-address-family

! Configure the NVE (VXLAN Tunnel) Overlay Interface
interface nve1
 no ip address
 source-interface Loopback10
 host-reachability protocol bgp
 member vni 10010 ingress-replication
!


! ------------------------------------------------------------------------------
! SECTION 4: CUSTOMER ACCESS + ANYCAST GATEWAY CONFIG
! ------------------------------------------------------------------------------

! On Catalyst 9500 Switches ONLY:
vlan 10
 name Tenant_A
!
vlan configuration 10
 member evpn-instance 10 vni 10010
!
l2vpn evpn
 replication-type static
 router-id loopback10
!
l2vpn evpn instance 10 vlan-based
 encapsulation vxlan
 replication-type ingress
!
